<script>
// ══════════════════════════════════════════════════════════════════════
//  ⚙️  CONFIGURATION — swap these placeholders with your real values
// ══════════════════════════════════════════════════════════════════════
const CONFIG = {
  clientId:     '65780d2f68db435a91a633d18f01253e',       // ← replace
  clientSecret: 'f0f3e0589d4443e1a3d7233813f6c58c',   // ← replace

  // List of 360Learning certificate IDs to monitor
  // These are the internal _id values from your platform
  certificateIds: [
    '67850414324f319f63d45b49',   // ← replace
    '67850414324f319f63d45b49',   // ← replace
    '67850414324f319f63d45b49',   // ← replace
  ],

  // "Expiring soon" threshold in days
  expiryWarningDays: 30,

  // EU base URL
  baseUrl: 'https://app.360learning.com',
};
// ══════════════════════════════════════════════════════════════════════

let cachedToken = null;
let tokenExpiry  = 0;
let allRows      = [];
let donutChart   = null;
let currentFilter = 'all';

// ── Auth ──────────────────────────────────────────────────────────────
async function getToken() {
  if (cachedToken && Date.now() < tokenExpiry) return cachedToken;

  setStatus('Authenticating with 360Learning…', 'loading');
  const res = await fetch(`${CONFIG.baseUrl}/api/v2/oauth2/token`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({
      grant_type:    'client_credentials',
      client_id:     CONFIG.clientId,
      client_secret: CONFIG.clientSecret,
    }),
  });
  if (!res.ok) throw new Error(`Auth failed: ${res.status} ${res.statusText}`);
  const data = await res.json();
  cachedToken = data.access_token;
  tokenExpiry  = Date.now() + (parseInt(data.expires_in, 10) - 60) * 1000;
  return cachedToken;
}

// ── Paginated GET helper ──────────────────────────────────────────────
async function fetchAllPages(url, token) {
  const results = [];
  let nextUrl = url;
  while (nextUrl) {
    const res = await fetch(nextUrl, {
      headers: {
        'Authorization':   `Bearer ${token}`,
        '360-api-version': 'v2.0',
        'Accept':          'application/json',
      },
    });
    if (!res.ok) throw new Error(`API error ${res.status} — ${await res.text()}`);
    const data = await res.json();
    if (Array.isArray(data)) results.push(...data);
    // Follow Link header for next page if present
    const link = res.headers.get('Link') || '';
    const match = link.match(/<([^>]+)>;\s*rel="next"/);
    nextUrl = match ? match[1] : null;
  }
  return results;
}

// ── Classify a learner record ─────────────────────────────────────────
function classify(record) {
  const now = Date.now();
  const warn = CONFIG.expiryWarningDays * 86400 * 1000;

  // completedAt null → not yet earned
  if (!record.completedAt && !record.certificateId) return 'not-earned';
  // No dueDate → valid indefinitely
  if (!record.dueDate) return 'valid';

  const due = new Date(record.dueDate).getTime();
  if (due < now)           return 'expired';
  if (due - now < warn)    return 'expiring';
  return 'valid';
}

// ── Main load ─────────────────────────────────────────────────────────
async function loadAll() {
  const btn = document.getElementById('refresh-btn');
  const icon = document.getElementById('refresh-icon');
  btn.disabled = true;
  icon.innerHTML = '<span class="spin">↻</span>';
  allRows = [];

  try {
    const token = await getToken();

    for (const certId of CONFIG.certificateIds) {
      setStatus(`Fetching sessions for certificate ${certId}…`, 'loading');

      // 1. Get all paths that use this certificate (via paths listing filtered by certificate)
      //    360Learning v2 doesn't have a direct "sessions by certificateId" endpoint, so we
      //    fetch all path sessions' user-stats and filter by certificateId in the response.
      //
      //    Strategy: GET /api/v2/paths → filter sessions linked to this cert → fetch user-stats.
      //    Because cert→path mapping isn't directly queryable, we use the user-stats endpoint
      //    filtered by certificateId (available as a response field) across all sessions.
      //
      //    Practical approach: fetch paths, iterate sessions, collect user-stats where certificateId matches.
      //    For large platforms, scope this by group or use a known pathId list.

      // Fetch paths (paginated)
      const paths = await fetchAllPages(`${CONFIG.baseUrl}/api/v2/paths`, token);

      for (const path of paths) {
        // Fetch sessions for each path
        const sessions = await fetchAllPages(
          `${CONFIG.baseUrl}/api/v2/paths/${path._id}/sessions`, token
        );

        for (const session of sessions) {
          // Fetch user-stats for each session
          const stats = await fetchAllPages(
            `${CONFIG.baseUrl}/api/v2/paths/${path._id}/sessions/${session._id}/user-stats`, token
          );

          // Keep only rows where the certificateId matches our target
          for (const stat of stats) {
            if (stat.certificateId === certId) {
              allRows.push({
                certId,
                certLabel: `…${certId.slice(-6)}`,
                userId:    stat.userId,
                completedAt: stat.completedAt,
                dueDate:   stat.dueDate,
                status:    classify(stat),
              });
            }
          }
        }
      }
    }

    renderAll();
    setStatus(`Loaded ${allRows.length} learner records across ${CONFIG.certificateIds.length} certificate(s)`, 'ok');
    document.getElementById('last-updated').textContent = new Date().toLocaleTimeString();

  } catch (err) {
    console.error(err);
    setStatus(`Error: ${err.message}`, 'error');
  } finally {
    btn.disabled = false;
    icon.textContent = '↻';
  }
}

// ── Render ────────────────────────────────────────────────────────────
function renderAll() {
  const counts = { valid: 0, expiring: 0, expired: 0, 'not-earned': 0 };
  for (const r of allRows) counts[r.status]++;
  const total = allRows.length;

  // KPIs
  document.getElementById('kpi-total').textContent    = total;
  document.getElementById('kpi-valid').textContent    = counts.valid;
  document.getElementById('kpi-expiring').textContent = counts.expiring;
  document.getElementById('kpi-expired').textContent  = counts.expired;
  document.getElementById('chart-total').textContent  = total;

  // Percentages
  const pct = v => total ? Math.round(v / total * 100) + '%' : '0%';
  document.getElementById('pct-valid').textContent      = pct(counts.valid);
  document.getElementById('pct-expiring').textContent   = pct(counts.expiring);
  document.getElementById('pct-expired').textContent    = pct(counts.expired);
  document.getElementById('pct-not-earned').textContent = pct(counts['not-earned']);

  // Donut chart
  const chartData = [counts.valid, counts.expiring, counts.expired, counts['not-earned']];
  const chartColors = ['#22c98a', '#f5a623', '#f04f5e', '#6b6f82'];

  if (donutChart) {
    donutChart.data.datasets[0].data = chartData;
    donutChart.update();
  } else {
    const ctx = document.getElementById('donut-chart').getContext('2d');
    donutChart = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Valid', 'Expiring Soon', 'Expired', 'Not Earned'],
        datasets: [{ data: chartData, backgroundColor: chartColors, borderWidth: 0, hoverOffset: 4 }],
      },
      options: {
        cutout: '72%',
        plugins: { legend: { display: false }, tooltip: {
          callbacks: {
            label: ctx => ` ${ctx.label}: ${ctx.raw} (${pct(ctx.raw)})`,
          },
          backgroundColor: '#1c1f2b',
          titleColor: '#e8eaf2',
          bodyColor: '#a0a4bb',
          borderColor: '#272a36',
          borderWidth: 1,
          padding: 10,
        }},
        animation: { duration: 500 },
      },
    });
  }

  // Table
  renderTable(currentFilter);
}

function renderTable(filter) {
  currentFilter = filter;
  const tbody = document.getElementById('table-body');

  const filtered = filter === 'all' ? allRows : allRows.filter(r => r.status === filter);

  if (filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6" class="empty-state">No records match this filter.</td></tr>`;
    return;
  }

  const now = Date.now();
  tbody.innerHTML = filtered.map(r => {
    const daysLeft = r.dueDate
      ? Math.ceil((new Date(r.dueDate).getTime() - now) / 86400000)
      : null;

    const daysStr = daysLeft === null
      ? '<span style="color:var(--muted)">No expiry</span>'
      : daysLeft < 0
        ? `<span style="color:var(--expired)">−${Math.abs(daysLeft)}d</span>`
        : `<span style="color:${daysLeft <= 30 ? 'var(--expiring)' : 'var(--valid)'}">${daysLeft}d</span>`;

    const badgeMap = {
      valid:       `<span class="badge valid"><span class="badge-dot" style="background:var(--valid)"></span>Valid</span>`,
      expiring:    `<span class="badge expiring"><span class="badge-dot" style="background:var(--expiring)"></span>Expiring Soon</span>`,
      expired:     `<span class="badge expired"><span class="badge-dot" style="background:var(--expired)"></span>Expired</span>`,
      'not-earned':`<span class="badge not-earned"><span class="badge-dot" style="background:var(--not-earned)"></span>Not Earned</span>`,
    };

    const fmtDate = iso => iso ? new Date(iso).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—';

    return `<tr>
      <td class="mono" style="color:var(--muted);font-size:11px">${r.certLabel}</td>
      <td class="mono" style="font-size:11px;color:var(--muted)">${r.userId.slice(0, 16)}…</td>
      <td>${badgeMap[r.status]}</td>
      <td style="color:var(--muted)">${fmtDate(r.completedAt)}</td>
      <td style="color:var(--muted)">${fmtDate(r.dueDate)}</td>
      <td>${daysStr}</td>
    </tr>`;
  }).join('');
}

function filterTable(filter, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderTable(filter);
}

// ── Status bar ────────────────────────────────────────────────────────
function setStatus(msg, type) {
  const bar  = document.getElementById('status-bar');
  const dot  = document.getElementById('status-dot');
  const text = document.getElementById('status-text');
  bar.className   = `status-bar${type === 'error' ? ' error' : ''}`;
  dot.className   = `dot${type === 'ok' ? ' active' : type === 'error' ? ' err' : ''}`;
  text.textContent = msg;
}
</script>
</body>
</html>
