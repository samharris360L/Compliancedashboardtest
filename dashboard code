<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>360Learning · Certificate Expiry Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

</head>
<body>

<style>

  ─────────────────────────────────────────────────────────────────────── */

  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,500;0,700;1,300&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0e0f14;
    --surface:   #16181f;
    --border:    #272a36;
    --text:      #e8eaf2;
    --muted:     #6b6f82;
    --accent:    #5b6aff;

    --valid:     #22c98a;
    --expiring:  #f5a623;
    --expired:   #f04f5e;
    --not-earned:#6b6f82;

    --radius: 12px;
    --font-mono: 'DM Mono', monospace;
    --font-sans: 'DM Sans', sans-serif;
  }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
  }

  .widget {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Header */
  .header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .header-left h1 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .header-left p {
    color: var(--muted);
    font-size: 12px;
    margin-top: 2px;
  }
  .refresh-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    padding: 7px 14px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .refresh-btn:hover { border-color: var(--accent); background: #1c1f2b; }
  .refresh-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .spin { animation: spin 1s linear infinite; display: inline-block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Warning banner */
  .warn-banner {
    background: #2a1f10;
    border: 1px solid #6b3d0e;
    border-radius: var(--radius);
    padding: 10px 14px;
    font-size: 11.5px;
    color: #f5a623;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  .warn-icon { flex-shrink: 0; margin-top: 1px; }

  /* Status bar */
  .status-bar {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 14px;
    min-height: 34px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .status-bar.error { color: var(--expired); border-color: #4a1c22; background: #1e0d10; }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--muted); flex-shrink: 0; }
  .dot.active { background: var(--valid); box-shadow: 0 0 6px var(--valid); }
  .dot.err    { background: var(--expired); }

  /* KPI row */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  @media (max-width: 560px) { .kpi-row { grid-template-columns: repeat(2, 1fr); } }

  .kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 0.2s;
  }
  .kpi-card:hover { border-color: #3a3f54; }
  .kpi-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--muted);
  }
  .kpi-value {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 500;
    line-height: 1;
  }
  .kpi-sub { font-size: 11px; color: var(--muted); }
  .kpi-card.valid   .kpi-value { color: var(--valid); }
  .kpi-card.expiring .kpi-value { color: var(--expiring); }
  .kpi-card.expired .kpi-value { color: var(--expired); }
  .kpi-card.total   .kpi-value { color: var(--text); }

  /* Main grid */
  .main-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 16px;
  }
  @media (max-width: 680px) { .main-grid { grid-template-columns: 1fr; } }

  /* Chart panel */
  .chart-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .chart-panel h3 {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--muted);
    align-self: flex-start;
  }
  .chart-wrap {
    position: relative;
    width: 180px;
    height: 180px;
  }
  .chart-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .chart-center-num {
    font-family: var(--font-mono);
    font-size: 26px;
    font-weight: 500;
    color: var(--text);
  }
  .chart-center-lbl {
    font-size: 10px;
    color: var(--muted);
  }
  .legend {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
  }
  .legend-left { display: flex; align-items: center; gap: 8px; }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .legend-pct { font-family: var(--font-mono); color: var(--muted); font-size: 11px; }

  /* Table panel */
  .table-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .table-panel-header {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }
  .table-panel-header h3 {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--muted);
  }
  .filter-tabs {
    display: flex;
    gap: 4px;
  }
  .tab-btn {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .tab-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .tab-btn:hover:not(.active) { border-color: #3a3f54; color: var(--text); }

  .cert-table-wrap { overflow-x: auto; flex: 1; }
  table { width: 100%; border-collapse: collapse; }
  thead tr { border-bottom: 1px solid var(--border); }
  th {
    padding: 10px 16px;
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    white-space: nowrap;
  }
  td {
    padding: 10px 16px;
    font-size: 12.5px;
    border-bottom: 1px solid #1c1f2a;
    white-space: nowrap;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #1b1e29; }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
  }
  .badge-dot { width: 5px; height: 5px; border-radius: 50%; }
  .badge.valid    { background: #0d2e20; color: var(--valid); }
  .badge.expiring { background: #2e2010; color: var(--expiring); }
  .badge.expired  { background: #2e0d13; color: var(--expired); }
  .badge.not-earned { background: #1c1f2a; color: var(--muted); }

  .mono { font-family: var(--font-mono); }

  /* Skeleton / empty */
  .empty-state {
    padding: 40px 16px;
    text-align: center;
    color: var(--muted);
    font-size: 13px;
  }
  .skeleton-row td {
    animation: pulse 1.4s ease infinite;
  }
  @keyframes pulse { 0%,100%{opacity:.4} 50%{opacity:.9} }
  .sk { background: var(--border); border-radius: 4px; height: 12px; display: inline-block; }
</style>
<div class="widget">



  <!-- ── HEADER ───────────────────────────────────────────── -->
  <div class="header">
    <div class="header-left">
      <h1>Certificate Expiry Dashboard</h1>
      <p>Live data · 360Learning EU · <span id="last-updated">Never refreshed</span></p>
    </div>
    <button class="refresh-btn" id="refresh-btn" onclick="loadAll()">
      <span id="refresh-icon">↻</span> Refresh
    </button>
  </div>

  <!-- ── STATUS ───────────────────────────────────────────── -->
  <div class="status-bar" id="status-bar">
    <span class="dot" id="status-dot"></span>
    <span id="status-text">Idle — press Refresh to load data</span>
  </div>

  <!-- ── KPI ROW ──────────────────────────────────────────── -->
  <div class="kpi-row">
    <div class="kpi-card total">
      <div class="kpi-label">Total Learners</div>
