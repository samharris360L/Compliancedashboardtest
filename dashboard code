          <button class="tab-btn active" onclick="filterTable('all', this)">All</button>
          <button class="tab-btn" onclick="filterTable('valid', this)">Valid</button>
          <button class="tab-btn" onclick="filterTable('expiring', this)">Expiring</button>
          <button class="tab-btn" onclick="filterTable('expired', this)">Expired</button>
          <button class="tab-btn" onclick="filterTable('not-earned', this)">Not Earned</button>
