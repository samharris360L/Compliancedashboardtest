        <canvas id="donut-chart"></canvas>
        <div class="chart-center">
          <span class="chart-center-num" id="chart-total">—</span>
          <span class="chart-center-lbl">records</span>
        </div>
      </div>
      <div class="legend" id="legend">
        <div class="legend-item"><div class="legend-left"><div class="legend-dot" style="background:var(--valid)"></div>Valid</div>       <span class="legend-pct" id="pct-valid">—</span></div>
        <div class="legend-item"><div class="legend-left"><div class="legend-dot" style="background:var(--expiring)"></div>Expiring Soon</div><span class="legend-pct" id="pct-expiring">—</span></div>
        <div class="legend-item"><div class="legend-left"><div class="legend-dot" style="background:var(--expired)"></div>Expired</div>     <span class="legend-pct" id="pct-expired">—</span></div>
        <div class="legend-item"><div class="legend-left"><div class="legend-dot" style="background:var(--not-earned)"></div>Not Earned</div><span class="legend-pct" id="pct-not-earned">—</span></div>
